# Backend runtime
HOST=0.0.0.0
PORT=18901

# Required: point to an absolute SQLite path or PostgreSQL DSN
DATABASE_URL=sqlite+aiosqlite:///ABSOLUTE/PATH/TO/state/nocturne.db

# Optional: enable Bearer auth for backend API
API_TOKEN=

# Optional: boot / browse defaults
VALID_DOMAINS=core,project,preferences,system
CORE_MEMORY_URIS=core://agent,preferences://user,core://workflow
